# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Tells Git which files to NEVER track or commit
#
# WHY THIS MATTERS:
#   - .env contains your database password. NEVER push it to GitHub.
#   - __pycache__ and .pyc files are auto-generated — no need to track them.
#   - logs/ can contain sensitive info and grow very large.
#   - venv/ is your virtual environment — it's huge and machine-specific.
# ─────────────────────────────────────────────────────────────────────────────

# Secret environment file — NEVER commit this!
.env

# Python cache files — auto-generated, machine-specific
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environment folders
venv/
env/
.venv/
ENV/

# Log files — can grow large and contain sensitive info
logs/*.log

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS-generated files
.DS_Store
Thumbs.db

# Distribution / packaging
*.egg-info/
dist/
build/
