# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Template for environment variables
#
# HOW TO USE:
#   1. Copy this file:   copy .env.example .env
#   2. Fill in your own values in the .env file
#   3. NEVER commit .env to Git (it's already in .gitignore)
#
# WHY ENV VARS?
#   We never hardcode passwords or secrets in Python code because:
#   - The code might be pushed to GitHub (public!)
#   - Team members have different database credentials
#   - Production vs development settings differ
# ─────────────────────────────────────────────────────────────────────────────

# The hostname or IP address of your PostgreSQL server
# For a local installation, this is always "localhost"
POSTGRES_HOST=localhost

# The port PostgreSQL listens on (default is 5432, almost never changes)
POSTGRES_PORT=5432

# The name of the database you created for this project
# Example: steam_reviews  (you create this with: CREATE DATABASE steam_reviews;)
POSTGRES_DB=steam_reviews

# Your PostgreSQL username
# Default superuser is "postgres" on most installations
POSTGRES_USER=postgres

# Your PostgreSQL password (the one you set during installation)
POSTGRES_PASSWORD=your_password_here
